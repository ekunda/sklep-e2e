# Skopiuj do .env i uzupełnij, żeby uruchomić aplikację lokalnie (npm run dev).
# UWAGA: Testy (integracyjne i E2E) NIE używają tych wartości — one
# wstrzykują DATABASE_URL/REDIS_URL z kontenerów Testcontainers.

# Port serwera aplikacji
PORT=3000

# Połączenie z PostgreSQL (dla trybu dev — np. lokalny docker-compose)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sklep

# Połączenie z Redis (dla trybu dev)
REDIS_URL=redis://localhost:6379

# Sekret do podpisywania tokenów JWT
JWT_SECRET=dev-secret-change-me

# Środowisko: development | test | production
NODE_ENV=development
